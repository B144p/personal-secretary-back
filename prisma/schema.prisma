generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  google_id     String   @unique
  email         String   @unique
  name          String?
  avartarUrl    String?
  refresh_token String
  createAt      DateTime @default(now())
  updateAt      DateTime @updatedAt

  @@map("user")
}

model Plan {
  id         String   @id @default(uuid())
  title      String
  created_at DateTime @default(now())

  tasks Task[]

  @@map("plan")
}

model Task {
  id              String   @id @default(uuid())
  plan_id         String
  title           String
  estimated_hours Int
  priority        String
  status          String
  created_at      DateTime @default(now())

  plan Plan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("task")
}

model CategoryRule {
  id       String         @id @default(uuid())
  keyword  String
  category EEventCategory @default(UNKNOWN)
  tags     String[]
  createAt DateTime       @default(now())
  updateAt DateTime       @updatedAt

  @@map("category_rule")
}

enum EEventCategory {
  DEEP_WORK
  MEETING
  CHORE
  HEALTH
  PERSONAL
  UNKNOWN
}
