generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  google_id     String   @unique
  email         String   @unique
  name          String?
  avartar_url   String?
  refresh_token String
  create_at     DateTime @default(now())
  update_at     DateTime @updatedAt

  user_state UserState?

  @@map("user")
}

model UserState {
  id      String @id @default(cuid())
  user_id String @unique

  last_calendar_sync DateTime?

  user User @relation(fields: [user_id], references: [id])

  @@map("user_state")
}

model Plan {
  id         String   @id @default(uuid())
  title      String
  created_at DateTime @default(now())

  tasks Task[]

  @@map("plan")
}

model Task {
  id              String   @id @default(uuid())
  plan_id         String
  title           String
  estimated_hours Int
  priority        String
  status          String
  created_at      DateTime @default(now())

  plan Plan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("task")
}

model CategoryRule {
  id       String         @id @default(uuid())
  keyword  String         @unique
  category EEventCategory @default(UNKNOWN)

  create_at    DateTime                 @default(now())
  update_at    DateTime                 @updatedAt
  keyword_tags CategoryRuleKeywordTag[]

  @@map("category_rule")
}

model CategoryRuleTag {
  id  String @id @default(uuid())
  tag String @unique

  create_at    DateTime                 @default(now())
  update_at    DateTime                 @updatedAt
  keyword_tags CategoryRuleKeywordTag[]

  @@map("category_rule_tag")
}

model CategoryRuleKeywordTag {
  tag_id           String
  category_rule_id String

  create_at DateTime @default(now())
  update_at DateTime @updatedAt

  category_rule CategoryRule    @relation(fields: [category_rule_id], references: [id], onDelete: Cascade)
  tag           CategoryRuleTag @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([category_rule_id, tag_id])
  @@map("category_rule_keyword_tag")
}

enum EEventCategory {
  DEEP_WORK
  MEETING
  CHORE
  HEALTH
  PERSONAL
  UNKNOWN
}
