generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  google_id     String   @unique
  email         String   @unique
  name          String?
  avartarUrl    String?
  refresh_token String
  create_at     DateTime @default(now())
  update_at     DateTime @updatedAt

  @@map("user")
}

model Plan {
  id         String   @id @default(uuid())
  title      String
  created_at DateTime @default(now())

  tasks Task[]

  @@map("plan")
}

model Task {
  id              String   @id @default(uuid())
  plan_id         String
  title           String
  estimated_hours Int
  priority        String
  status          String
  created_at      DateTime @default(now())

  plan Plan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("task")
}

model CategoryRule {
  id       String         @id @default(uuid())
  keyword  String         @unique
  category EEventCategory @default(UNKNOWN)

  create_at   DateTime                 @default(now())
  update_at   DateTime                 @updatedAt
  keywordTags CategoryRuleKeywordTag[]

  @@map("category_rule")
}

model CategoryRuleTag {
  id  String @id @default(uuid())
  tag String @unique

  create_at   DateTime                 @default(now())
  update_at   DateTime                 @updatedAt
  keywordTags CategoryRuleKeywordTag[]

  @@map("category_rule_tag")
}

model CategoryRuleKeywordTag {
  tagId          String
  categoryRuleId String

  create_at DateTime @default(now())
  update_at DateTime @updatedAt

  categoryRule CategoryRule    @relation(fields: [categoryRuleId], references: [id], onDelete: Cascade)
  tag          CategoryRuleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([categoryRuleId, tagId])
  @@map("category_rule_keyword_tag")
}

enum EEventCategory {
  DEEP_WORK
  MEETING
  CHORE
  HEALTH
  PERSONAL
  UNKNOWN
}
