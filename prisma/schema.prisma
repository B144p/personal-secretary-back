generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  google_id     String   @unique
  email         String   @unique
  name          String?
  avartar_url   String?
  refresh_token String
  create_at     DateTime @default(now())
  update_at     DateTime @updatedAt

  user_state UserState?
  plan       Plan[]

  @@map("user")
}

model UserState {
  id      String @id @default(cuid())
  user_id String @unique

  last_calendar_sync DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_state")
}

model Plan {
  id          String           @id @default(uuid())
  user_id     String           @unique
  title       String
  source_id   String?
  source_type EPlanSourceType?
  status      EPlanStatus

  create_at DateTime @default(now())
  update_at DateTime @updatedAt

  user  User   @relation(fields: [user_id], references: [id])
  tasks Task[]

  @@map("plan")
}

model Task {
  id      String      @id @default(uuid())
  plan_id String
  title   String
  status  ETaskStatus @default(HOLD)

  create_at DateTime @default(now())
  update_at DateTime @updatedAt

  plan Plan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("task")
}

model CategoryRule {
  id       String         @id @default(uuid())
  keyword  String         @unique
  category EEventCategory @default(UNKNOWN)

  create_at    DateTime                 @default(now())
  update_at    DateTime                 @updatedAt
  keyword_tags CategoryRuleKeywordTag[]

  @@map("category_rule")
}

model CategoryRuleTag {
  id  String @id @default(uuid())
  tag String @unique

  create_at    DateTime                 @default(now())
  update_at    DateTime                 @updatedAt
  keyword_tags CategoryRuleKeywordTag[]

  @@map("category_rule_tag")
}

model CategoryRuleKeywordTag {
  tag_id           String
  category_rule_id String

  create_at DateTime @default(now())
  update_at DateTime @updatedAt

  category_rule CategoryRule    @relation(fields: [category_rule_id], references: [id], onDelete: Cascade)
  tag           CategoryRuleTag @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([category_rule_id, tag_id])
  @@map("category_rule_keyword_tag")
}

enum EEventCategory {
  DEEP_WORK
  MEETING
  CHORE
  HEALTH
  PERSONAL
  UNKNOWN
}

enum EPlanSourceType {
  GENERATE
  CALENDAR
}

enum EPlanStatus {
  DRAFT
  READY
  SCHEDULED
  HOLD
}

enum ETaskStatus {
  HOLD
  PENDING
  INPROGRESS
  DONE
}
